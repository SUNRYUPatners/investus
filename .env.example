# Alpha Vantage API Key
# 무료 API 키 발급: https://www.alphavantage.co/support/#api-key
# 키를 추가하면 lib/api.ts 의 주석 처리된 Alpha Vantage 코드가 활성화됩니다.
ALPHA_VANTAGE_API_KEY=your_api_key_here

# ── PortOne V2 결제 ────────────────────────────────
# 포트원 콘솔 → 상점 → 상점 ID
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 콘솔 → 결제 연동 → 채널 → 채널키 (특정 PG 지정)
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 콘솔 → 개발자 콘솔 → API Secret (서버 전용, PUBLIC 아님)
PORTONE_API_SECRET=your_portone_api_secret
# 콘솔 → 웹훅 → 시크릿 (서버 전용)
PORTONE_WEBHOOK_SECRET=your_portone_webhook_secret

# ── Vercel Cron 보호 ───────────────────────────────
# Vercel Cron이 호출할 때 Authorization: Bearer <이 값> 매칭 확인
CRON_SECRET=random_long_string

# Vercel 배포 시 Vercel 대시보드 → Settings → Environment Variables 에 추가
