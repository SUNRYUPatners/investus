{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/push/market-open", "schedule": "30 13 * * 1-5" },
    { "path": "/api/push/market-open", "schedule": "30 14 * * 1-5" },
    { "path": "/api/cron/market-open-posts", "schedule": "35 13 * * 1-5" },
    { "path": "/api/cron/market-open-posts", "schedule": "35 14 * * 1-5" },
    { "path": "/api/cron/market-open-posts?session=midday", "schedule": "5 16 * * 1-5" },
    { "path": "/api/cron/market-open-posts?session=midday", "schedule": "5 17 * * 1-5" },
    { "path": "/api/cron/market-open-posts?session=close", "schedule": "5 20 * * 1-5" },
    { "path": "/api/cron/market-open-posts?session=close", "schedule": "5 21 * * 1-5" },
    { "path": "/api/cron/market-summary-close", "schedule": "10 20 * * 1-5" },
    { "path": "/api/cron/market-summary-close", "schedule": "10 21 * * 1-5" },
    { "path": "/api/push/report-update", "schedule": "30 23 * * *" },
    { "path": "/api/market-data", "schedule": "0 22 * * *" },
    { "path": "/api/market-data", "schedule": "20 20 * * 1-5" },
    { "path": "/api/market-data", "schedule": "20 21 * * 1-5" },
    { "path": "/api/cron/subscription-recharge", "schedule": "0 18 * * *" }
  ]
}
